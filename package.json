{
  "name": "global-allianz-app",
  "version": "1.0.0",
  "description": "Global Allianz Insurance Brokers - Full-stack web application",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=client\" \"npm run dev --workspace=server\"",
    "build": "npm run build --workspace=client",
    "start": "npm run start --workspace=server",
    "install:all": "npm install",
    "clean": "rm -rf client/node_modules server/node_modules node_modules"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "insurance",
    "brokerage",
    "react",
    "nodejs",
    "mongodb"
  ],
  "author": "Global Allianz Insurance Brokers",
  "license": "ISC"
}